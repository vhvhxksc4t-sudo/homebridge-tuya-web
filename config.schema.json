{
  "pluginAlias": "TuyaWebPlatform",
  "pluginType": "platform",
  "singular": true,
  "headerDisplay": "Homebridge plugin for Tuya devices using the official Tuya IoT Platform API. See the [setup guide](https://github.com/vhvhxksc4t-sudo/homebridge-tuya-web#readme) for instructions on creating your API credentials.",
  "footerDisplay": "For issues or questions, please [open an issue on GitHub](https://github.com/vhvhxksc4t-sudo/homebridge-tuya-web/issues).",
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "required": true,
        "default": "TuyaWebPlatform",
        "description": "You shouldn't need to change this."
      },
      "options": {
        "title": "",
        "type": "object",
        "required": true,
        "properties": {
          "accessId": {
            "title": "Access ID",
            "type": "string",
            "required": true,
            "description": "Your Tuya IoT Platform project Access ID (Client ID), found on the project Overview page at platform.tuya.com."
          },
          "accessSecret": {
            "title": "Access Secret",
            "type": "string",
            "required": true,
            "description": "Your Tuya IoT Platform project Access Secret (Client Secret), found on the project Overview page."
          },
          "region": {
            "title": "Data Center Region",
            "type": "string",
            "default": "us",
            "description": "The data center region you selected when creating your Tuya IoT Platform project. Must match the region your Smart Life account is registered in.",
            "oneOf": [
              {
                "title": "Western America (US & Canada)",
                "enum": ["us"]
              },
              {
                "title": "Central Europe",
                "enum": ["eu"]
              },
              {
                "title": "China",
                "enum": ["cn"]
              },
              {
                "title": "India",
                "enum": ["in"]
              }
            ],
            "required": false
          },
          "pollingInterval": {
            "title": "Polling Interval",
            "type": "number",
            "description": "How often (in seconds) to poll the cloud for device state updates. Leave empty to only fetch on demand. Recommended minimum: 30.",
            "required": false,
            "minimum": 30
          }
        }
      },
      "defaults": {
        "title": "Device Settings",
        "description": "Override settings for individual devices.",
        "type": "array",
        "items": {
          "title": "Device Override",
          "type": "object",
          "properties": {
            "id": {
              "title": "Device name or ID",
              "type": "string",
              "description": "The device name from your app, or the Tuya device ID shown in the Homebridge log at startup.",
              "required": true
            },
            "device_type": {
              "title": "Device type",
              "type": "string",
              "description": "Override the detected device type.",
              "oneOf": [
                {
                  "title": "Dimmer",
                  "enum": ["dimmer"]
                },
                {
                  "title": "Fan",
                  "enum": ["fan"]
                },
                {
                  "title": "Garage Door",
                  "enum": ["garage"]
                },
                {
                  "title": "Light",
                  "enum": ["light"]
                },
                {
                  "title": "Outlet",
                  "enum": ["outlet"]
                },
                {
                  "title": "Scene",
                  "enum": ["scene"]
                },
                {
                  "title": "Switch",
                  "enum": ["switch"]
                },
                {
                  "title": "Temperature Sensor",
                  "enum": ["temperature_sensor"]
                },
                {
                  "title": "Thermostat",
                  "enum": ["climate"]
                },
                {
                  "title": "Window Cover",
                  "enum": ["cover"]
                },
                {
                  "title": "Window",
                  "enum": ["window"]
                }
              ],
              "required": true
            },
            "min_temper": {
              "title": "Minimum Temperature (°C)",
              "type": "string",
              "pattern": "^-?\\d+(?:\\.[05])?$",
              "description": "Minimum settable temperature in HomeKit, in °C with half-degree increments.",
              "placeholder": "16",
              "required": false
            },
            "max_temper": {
              "title": "Maximum Temperature (°C)",
              "type": "string",
              "pattern": "^-?\\d+(?:\\.[05])?$",
              "description": "Maximum settable temperature in HomeKit, in °C with half-degree increments.",
              "placeholder": "30",
              "required": false
            },
            "min_brightness": {
              "title": "Minimum Brightness (raw)",
              "type": "string",
              "pattern": "^-?\\d+$",
              "description": "Raw brightness value the device reports when off. Used to scale the brightness range.",
              "required": false
            },
            "max_brightness": {
              "title": "Maximum Brightness (raw)",
              "type": "string",
              "pattern": "^-?\\d+$",
              "description": "Raw brightness value the device reports at full brightness. Used to scale the brightness range.",
              "required": false
            },
            "min_kelvin": {
              "title": "Minimum Kelvin (raw)",
              "type": "string",
              "pattern": "^-?\\d+$",
              "description": "Raw value the device reports at warmest (most red) color temperature.",
              "required": false
            },
            "max_kelvin": {
              "title": "Maximum Kelvin (raw)",
              "type": "string",
              "pattern": "^-?\\d+$",
              "description": "Raw value the device reports at coolest (most blue) color temperature.",
              "required": false
            },
            "current_temperature_factor": {
              "title": "Temperature Factor",
              "type": "string",
              "pattern": "^\\d+(?:\\.\\d+)?$",
              "description": "Multiplier for the current temperature reading. Use 0.1 if HomeKit shows 220 when the actual temperature is 22°C.",
              "placeholder": "0.1",
              "required": false
            },
            "target_temperature_factor": {
              "title": "Target Temperature Factor",
              "type": "string",
              "pattern": "^\\d+(?:\\.\\d+)?$",
              "description": "Multiplier for the target temperature. Defaults to 1 (no change).",
              "placeholder": "0.1",
              "required": false
            },
            "cover_characteristics": {
              "title": "Features",
              "type": "array",
              "uniqueItems": true,
              "items": {
                "title": "Feature",
                "type": "string",
                "enum": ["Stop"]
              }
            },
            "dimmer_characteristics": {
              "title": "Features",
              "type": "array",
              "uniqueItems": true,
              "items": {
                "title": "Feature",
                "type": "string",
                "enum": ["Brightness"]
              }
            },
            "fan_characteristics": {
              "title": "Features",
              "type": "array",
              "uniqueItems": true,
              "items": {
                "title": "Feature",
                "type": "string",
                "enum": ["Speed"]
              }
            },
            "light_characteristics": {
              "title": "Features",
              "type": "array",
              "uniqueItems": true,
              "items": {
                "title": "Feature",
                "type": "string",
                "enum": ["Brightness", "Color", "Color Temperature"]
              }
            }
          }
        }
      },
      "scenes": {
        "title": "Expose Tuya scenes to HomeKit",
        "type": "boolean",
        "required": true,
        "default": false
      },
      "scenesWhitelist": {
        "title": "Scenes to expose to HomeKit",
        "type": "array",
        "required": false,
        "items": {
          "title": "Scene name or ID",
          "type": "string",
          "required": true
        }
      },
      "hiddenAccessories": {
        "title": "Accessories to hide from HomeKit",
        "type": "array",
        "required": false,
        "items": {
          "title": "Accessory name or ID",
          "type": "string",
          "required": true
        }
      }
    }
  },
  "layout": [
    {
      "type": "flex",
      "flex-flow": "row wrap",
      "items": [
        "options.accessId",
        {
          "key": "options.accessSecret",
          "type": "password"
        }
      ]
    },
    "options.region",
    {
      "type": "fieldset",
      "title": "Device Settings",
      "expandable": true,
      "expanded": false,
      "items": [
        {
          "type": "array",
          "items": [
            {
              "key": "defaults[].id"
            },
            {
              "key": "defaults[].device_type"
            },
            {
              "key": "defaults[].cover_characteristics",
              "condition": {
                "functionBody": "return (['cover', 'window'].includes(model.defaults[arrayIndices].device_type))"
              }
            },
            {
              "key": "defaults[].dimmer_characteristics",
              "condition": {
                "functionBody": "return (model.defaults[arrayIndices].device_type == 'dimmer')"
              }
            },
            {
              "key": "defaults[].fan_characteristics",
              "condition": {
                "functionBody": "return (model.defaults[arrayIndices].device_type == 'fan')"
              }
            },
            {
              "key": "defaults[].light_characteristics",
              "condition": {
                "functionBody": "return (model.defaults[arrayIndices].device_type == 'light')"
              }
            },
            {
              "key": "defaults[].min_temper",
              "condition": {
                "functionBody": "return (model.defaults[arrayIndices].device_type == 'climate')"
              }
            },
            {
              "key": "defaults[].max_temper",
              "condition": {
                "functionBody": "return (model.defaults[arrayIndices].device_type == 'climate')"
              }
            },
            {
              "key": "defaults[].min_brightness",
              "condition": {
                "functionBody": "return (model.defaults[arrayIndices].light_characteristics?.includes('Brightness') || model.defaults[arrayIndices].dimmer_characteristics?.includes('Brightness'))"
              }
            },
            {
              "key": "defaults[].max_brightness",
              "condition": {
                "functionBody": "return (model.defaults[arrayIndices].light_characteristics?.includes('Brightness') || model.defaults[arrayIndices].dimmer_characteristics?.includes('Brightness'))"
              }
            },
            {
              "key": "defaults[].min_kelvin",
              "condition": {
                "functionBody": "return (model.defaults[arrayIndices].light_characteristics?.includes('Color Temperature'))"
              }
            },
            {
              "key": "defaults[].max_kelvin",
              "condition": {
                "functionBody": "return (model.defaults[arrayIndices].light_characteristics?.includes('Color Temperature'))"
              }
            },
            {
              "key": "defaults[].current_temperature_factor",
              "condition": {
                "functionBody": "return (['climate', 'temperature_sensor'].includes(model.defaults[arrayIndices].device_type))"
              }
            },
            {
              "key": "defaults[].target_temperature_factor",
              "condition": {
                "functionBody": "return (model.defaults[arrayIndices].device_type == 'climate')"
              }
            }
          ]
        }
      ]
    },
    {
      "type": "fieldset",
      "title": "Optional Settings",
      "expandable": true,
      "expanded": false,
      "items": ["options.pollingInterval"]
    },
    {
      "type": "fieldset",
      "title": "Advanced",
      "expandable": true,
      "expanded": false,
      "items": [
        {
          "title": "Hidden accessories",
          "type": "array",
          "description": "Accessories that should not be exposed to HomeKit.",
          "items": [
            {
              "key": "hiddenAccessories[]",
              "required": true
            }
          ]
        },
        {
          "type": "fieldset",
          "title": "Scenes",
          "items": [
            "scenes",
            {
              "title": "Whitelisted scenes",
              "type": "array",
              "description": "Specific scenes to expose to HomeKit. When left empty, all scenes are exposed.",
              "condition": {
                "functionBody": "return (model.scenes)"
              },
              "items": [
                {
                  "key": "scenesWhitelist[]",
                  "required": true
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
