{
  "displayName": "TuyaWebPlatform",
  "name": "homebridge-tuya-web-v2",
  "version": "2.1.0",
  "description": "Homebridge plugin for use with Tuya devices (uses Home Assistant Tuya Web API)",
  "homepage": "https://github.com/vhvhxksc4t-sudo/homebridge-tuya-web#readme",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "rimraf ./dist && tsc",
    "lint": "eslint **/src/**/*.ts",
    "prepublishOnly": "npm run lint && npm run build",
    "prettier": "prettier --check .",
    "release": "np",
    "test": "ts-mocha test/**/*.spec.ts",
    "watch": "npm run build && npm link && nodemon",
    "clear-cache": "rimraf ~/.homebridge/accessories/cachedAccessories && rimraf ~/.homebridge/persist/*"
  },
  "keywords": [
    "homebridge",
    "homebridge-plugin",
    "tuya",
    "smartlife",
    "tuyawebplatform",
    "tuyaweb"
  ],
  "author": "Milo Cesar <milocesar1@gmail.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^18.15.0 || ^20.7.0 || ^22.0.0 || ^24.0.0",
    "homebridge": "^1.6.0 || ^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vhvhxksc4t-sudo/homebridge-tuya-web"
  },
  "bugs": {
    "url": "https://github.com/vhvhxksc4t-sudo/homebridge-tuya-web/issues"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "diff": "^8.0.3",
    "tmp": "^0.2.4"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "lodash.debounce": "^4.0.8"
  },
  "devDependencies": {
    "@types/lodash.debounce": "^4.0.7",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.4",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "chai": "^4.5.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "homebridge": "^2.0.2",
    "mocha": "^10.7.3",
    "nodemon": "^3.1.14",
    "np": "^11.2.1",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.2",
    "ts-xor": "^1.3.0",
    "typescript": "^5.9.3"
  }
}
